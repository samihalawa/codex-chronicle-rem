<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.samihalawa.chronicle-rem-archive</string>
  <key>ProgramArguments</key>
  <array>
    <string>__HOME__/.codex/memories/extensions/chronicle/persistent_detailed_only_use_when_summaries_not_enough/scripts/archive_chronicle.sh</string>
  </array>
  <key>StartInterval</key>
  <integer>60</integer>
  <key>RunAtLoad</key>
  <true/>
  <key>StandardOutPath</key>
  <string>__HOME__/.codex/memories/extensions/chronicle/persistent_detailed_only_use_when_summaries_not_enough/logs/launchd.out.log</string>
  <key>StandardErrorPath</key>
  <string>__HOME__/.codex/memories/extensions/chronicle/persistent_detailed_only_use_when_summaries_not_enough/logs/launchd.err.log</string>
</dict>
</plist>

